# K8s base defaults. Canonical template: infra/config/env-templates/management-api.env.example
# Secrets come from Kubernetes Secrets in overlays.

DEFAULT_LOCALE=en-US
SUPPORTED_LOCALES=all-available
ACCOUNT_SIGNUP_MODE=admin_only_username
KEYVALDB_HOST=metaboost-keyvaldb
KEYVALDB_PORT=6379
DB_HOST=metaboost-db
DB_PORT=5432
DB_APP_NAME=metaboost_app
DB_APP_READ_USER=metaboost_app_read
DB_APP_READ_WRITE_USER=metaboost_app_read_write
DB_MANAGEMENT_NAME=metaboost_management
DB_MANAGEMENT_READ_WRITE_USER=metaboost_management_read_write
MANAGEMENT_API_EXPECTED_MIGRATION_FILENAME=0001_management_schema.sql
API_PORT=4000
MANAGEMENT_API_VERSION_PATH=/v1
MANAGEMENT_API_RELEASE=X.X.X-staging.N
API_PUBLIC_BASE_URL=http://api:4000
API_SERVER_BASE_URL=http://api:4000
WEB_PORT=4002
WEB_BASE_URL=http://web:4002
MANAGEMENT_API_PORT=4100
MANAGEMENT_API_PUBLIC_BASE_URL=http://management-api:4100
MANAGEMENT_API_SERVER_BASE_URL=http://management-api:4100
MANAGEMENT_WEB_PORT=4102
MANAGEMENT_WEB_BASE_URL=http://management-web:4102
MANAGEMENT_API_USER_AGENT=Metaboost Bot Local/Management-API/1
MANAGEMENT_API_COOKIE_DOMAIN=localhost
MANAGEMENT_API_CORS_ORIGINS=http://management-web:4102
MANAGEMENT_API_SESSION_COOKIE_NAME=management_api_session
MANAGEMENT_API_REFRESH_COOKIE_NAME=management_api_refresh
MANAGEMENT_API_JWT_ACCESS_EXPIRATION=3600
MANAGEMENT_API_JWT_REFRESH_EXPIRATION=3600
MANAGEMENT_API_USER_INVITATION_EXPIRATION=86400
STANDARD_ENDPOINT_REGISTRY_URL=https://raw.githubusercontent.com/v4v-io/metaboost-registry/main/registry/apps
STANDARD_ENDPOINT_REQUIRE_HTTPS=false
STANDARD_ENDPOINT_TRUST_PROXY=false
MANAGEMENT_API_AUTH_RATE_LIMIT_USE_KEYVALDB=false
API_EXCHANGE_RATES_FETCH_ENABLED=true
