    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "nanoid": "^5.1.9"
  },
  "devDependencies": {
    "@types/node": "^24.10.12",
    "typescript": "^5.9.2",
    "vitest": "^4.1.4"
  }
}
