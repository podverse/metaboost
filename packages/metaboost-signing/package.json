{
  "name": "metaboost-signing",
  "version": "0.1.9",
  "description": "Framework-agnostic helpers for minting AppAssertion JWTs for Metaboost Standard Endpoint POST /v1/standard/*",
  "type": "module",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/podverse/metaboost.git",
    "directory": "packages/metaboost-signing"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch --preserveWatchOutput",
    "lint": "eslint ./src --max-warnings 0",
    "lint:fix": "eslint ./src --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "jose": "^6.1.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.12",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  }
}
