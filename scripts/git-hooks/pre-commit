#!/bin/bash

# Boilerplate Pre-Commit Hook - Format staged files with Prettier
# Runs lint-staged (prettier --write on staged files).
# Works with: Node on PATH (nvm, nix develop, global), NixOS (nix develop), nvm-only.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
LINT_STAGED="$REPO_ROOT/node_modules/.bin/lint-staged"

if [[ ! -x "$LINT_STAGED" ]]; then
  echo "pre-commit: lint-staged not found (run npm install)."
  exit 1
fi

if command -v node >/dev/null 2>&1; then
  exec "$LINT_STAGED"
fi

if command -v nix >/dev/null 2>&1; then
  (cd "$REPO_ROOT" && nix develop --command bash -c 'exec ./node_modules/.bin/lint-staged')
  exit $?
fi

NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [[ -s "$NVM_DIR/nvm.sh" ]]; then
  (cd "$REPO_ROOT" && source "$NVM_DIR/nvm.sh" && (nvm use 2>/dev/null || true) && exec ./node_modules/.bin/lint-staged)
  exit $?
fi

echo "pre-commit: node not on PATH and nix/nvm not available. Run commit from a terminal with Node (nix develop, nvm, or PATH)."
exit 1
