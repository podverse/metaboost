{
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "printWidth": 100,
  "overrides": [
    { "files": ["*.yml", "*.yaml"], "options": { "singleQuote": false } },
    { "files": ["*.d.ts"], "options": { "singleQuote": false } },
    { "files": ["*.md", "*.mdc"], "options": { "embeddedLanguageFormatting": "off" } }
  ]
}
