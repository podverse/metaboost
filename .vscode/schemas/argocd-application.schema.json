{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "argocd-application.schema.json",
  "title": "Argo CD Application (minimal workspace schema)",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "argoproj.io/v1alpha1"
    },
    "kind": {
      "type": "string",
      "const": "Application"
    },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "namespace": { "type": "string" }
      },
      "additionalProperties": true
    },
    "spec": {
      "type": "object",
      "required": ["project", "source", "destination"],
      "properties": {
        "project": { "type": "string" },
        "source": {
          "type": "object",
          "properties": {
            "repoURL": { "type": "string" },
            "targetRevision": { "type": "string" },
            "path": { "type": "string" }
          },
          "additionalProperties": true
        },
        "destination": {
          "type": "object",
          "properties": {
            "server": { "type": "string" },
            "namespace": { "type": "string" }
          },
          "additionalProperties": true
        },
        "syncPolicy": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
