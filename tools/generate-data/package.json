{
  "name": "@metaboost/generate-data",
  "version": "0.1.8",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "lint": "eslint ./src --max-warnings 0",
    "lint:fix": "eslint ./src --fix",
    "type-check": "tsc --noEmit",
    "generate": "node dist/cli.js",
    "generate:main": "node dist/cli.js main --rows 100",
    "generate:management": "node dist/cli.js management --rows 100",
    "generate:both": "node dist/cli.js both --rows 100"
  },
  "devDependencies": {
    "@metaboost/helpers": "*",
    "@metaboost/management-orm": "*",
    "@metaboost/orm": "*",
    "@faker-js/faker": "^9.4.0",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^24.10.12",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.5",
    "typescript": "^5.9.2",
    "uuid": "^13.0.0"
  }
}
